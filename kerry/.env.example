# Copy to .env and edit. Every value is optional — Kerry runs offline with none set.

# Which generalist to run the loop on:
#   echo | paraphrase  -> offline, deterministic, no key required
#   anthropic          -> Claude (requires ANTHROPIC_API_KEY below)
KERRY_GENERALIST=echo

# The generalist to swap to in the sovereignty test.
KERRY_SWAP_GENERALIST=paraphrase

# How many cycles to climb the hill.
KERRY_CYCLES=4

# Frontier model used by the anthropic generalist.
KERRY_ANTHROPIC_MODEL=claude-opus-4-8

# Only needed when KERRY_GENERALIST=anthropic.
# ANTHROPIC_API_KEY=sk-ant-...
